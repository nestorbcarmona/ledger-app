# Copy to .env and adjust. main.ts loads dotenv from the project root.

# HTTP (default 3000)
PORT=3000

# Required for /accounts and /transactions (comma-separated)
LEDGER_API_KEYS=dev-key

# Optional: Redis for account cache + BullMQ after successful transactions
# REDIS_URL=redis://localhost:6379

# Account cache TTL in ms (default 30000)
# ACCOUNT_CACHE_TTL_MS=30000

# Optional: OpenTelemetry OTLP HTTP base (traces POST to {base}/v1/traces)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=ledger-app

# Rate limit: max THROTTLE_LIMIT requests per THROTTLE_TTL_MS (per API key or IP; /health and /metrics skipped)
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120

# NODE_ENV=development
